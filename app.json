{
  "expo": {
    "name": "Trakio",
    "slug": "trakio",
    "version": "1.1.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "trakio",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#18181b",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.trakio.mobile",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Trakio uses your location to record lap times and GPS traces on track.",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["instagram", "instagram-stories"],
        "NSPhotoLibraryUsageDescription": "Trakio may need access to your photo library to save or share session content.",
        "NSPhotoLibraryAddUsageDescription": "Trakio needs permission to save story images to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.trakio.mobile"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-system-ui",
      "expo-localization",
      "expo-media-library",
      "expo-image-picker",
      "expo-sqlite",
      ["expo-screen-orientation", { "initialOrientation": "PORTRAIT" }],
      [
        "react-native-share",
        {
          "ios": ["instagram", "instagram-stories"],
          "android": ["com.instagram.android"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "instagramAppId": "3072500352933301",
      "router": {},
      "eas": {
        "projectId": "55cde39e-cdc2-4804-8e1b-e4a05f1cd5eb"
      }
    }
  }
}
